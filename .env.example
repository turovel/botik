DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: set this if the bot should always use one common voice channel.
# If empty, /play and /join use the voice channel of the user who ran the command.
DEFAULT_VOICE_CHANNEL_ID=

# Optional: set for instant guild-only command deployment while developing.
# If empty, commands are deployed globally and may take longer to appear.
DISCORD_GUILD_ID=
